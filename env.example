#
# sloths-inventory environment variables example
#
# Copy to `.env` (optional) and adjust values as needed.
# The application loads env vars via `django-environ`.
#

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------

# Enable debug mode for local development.
DEBUG=1

# Required when DEBUG=0. For local dev it can be any value.
SECRET_KEY=unsafe-secret-key-for-local-dev

# Comma-separated list. Use explicit hostnames or "*" behind a trusted proxy.
ALLOWED_HOSTS=*

# Comma-separated list. Example values must include scheme.
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Production HTTPS hardening (opt-in for deployment compatibility).
# Enable cookie flags when the app is served over HTTPS.
# Enable HTTP->HTTPS redirects only when Django should perform redirects and
# proxy/TLS headers are configured correctly.
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0

# If the app runs behind a trusted reverse proxy that sets X-Forwarded-Proto:
# https, uncomment both values. Do not enable for untrusted proxies.
# SECURE_PROXY_SSL_HEADER_NAME=HTTP_X_FORWARDED_PROTO
# SECURE_PROXY_SSL_HEADER_VALUE=https

# -----------------------------------------------------------------------------
# Admin user (example)
# -----------------------------------------------------------------------------
#
# If set, `make run` and `make docker-run` will attempt to create a superuser via:
# `python manage.py createsuperuser --noinput` (it is safe to re-run).
#
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=password

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=database
DATABASE_USER=user
DATABASE_PASSWORD=password

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Defaults to DEBUG when DEBUG=1, else INFO.
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Inventory
# -----------------------------------------------------------------------------

# Correction window length in minutes (one setting, three anchors):
# - Latest operation: ``Operation.created_at`` (append-only head rule still applies).
# - Item fields: ``Item.created_at`` after the first operation exists for that item.
# - Catalog / device rows: ``created_at`` once the row is referenced by inventory;
#   unreferenced rows are not time-limited. Superusers bypass in the admin only.
# See README "Domain rules" and ``common.catalog_correction_window``.
INVENTORY_CORRECTION_WINDOW_MINUTES=10

# Hours until a transfer offer created from the user UI expires (0 = no automatic expiry).
INVENTORY_PENDING_TRANSFER_EXPIRATION_HOURS=168

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------

# Email backend: smtp (Mailhog)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=0
EMAIL_USE_SSL=0
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=10

# From address
DEFAULT_FROM_EMAIL=noreply@example.com
SERVER_EMAIL=noreply@example.com

# Async email retry settings
EMAIL_SEND_ASYNC=1
EMAIL_RETRY_MAX_RETRIES=2
EMAIL_RETRY_BASE_DELAY_SECONDS=60
EMAIL_RETRY_BACKOFF_FACTOR=2

# django-q2 task queue (PostgreSQL ORM broker; no Redis required)
Q_ASYNC=1
Q_CLUSTER_NAME=sloths_inventory
Q_WORKERS=1
Q_TIMEOUT=60
Q_RETRY=120
# Site URL for links in emails (e.g., password reset)
SITE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Process supervisor (manage.py start)
# -----------------------------------------------------------------------------

# Seconds all child processes share before SIGKILL is sent (shared deadline, not per-process).
# Set below Kubernetes terminationGracePeriodSeconds to retain control over the kill order.
GRACEFUL_TIMEOUT=25

# -----------------------------------------------------------------------------
# Internationalization / timezone
# -----------------------------------------------------------------------------

TIME_ZONE=UTC
