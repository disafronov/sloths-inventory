#: src/common/templates/login.html:13
msgid "Forgot your password?"
msgstr "Забыли пароль?"

#: src/common/templates/password_reset_complete.html:4
#: src/common/templates/password_reset_complete.html:8
msgid "Password Reset Complete"
msgstr "Сброс пароля завершен"

#: src/common/templates/password_reset_complete.html:9
msgid "Your password has been set. You can now log in with your new password."
msgstr "Ваш пароль установлен. Теперь вы можете войти с новым паролем."

#: src/common/templates/password_reset_complete.html:10
msgid "Log in"
msgstr "Войти"

#: src/common/templates/password_reset_confirm.html:4
#: src/common/templates/password_reset_confirm.html:9
msgid "Set New Password"
msgstr "Установить новый пароль"

#: src/common/templates/password_reset_confirm.html:10
msgid ""
"Please enter your new password twice so we can verify you typed it in "
"correctly."
msgstr ""
"Пожалуйста, введите новый пароль дважды, чтобы мы могли убедиться, что вы "
"ввели его правильно."

#: src/common/templates/password_reset_confirm.html:15
msgid "Change password"
msgstr "Сменить пароль"

#: src/common/templates/password_reset_confirm.html:18
msgid "Password Reset Failed"
msgstr "Ошибка сброса пароля"

#: src/common/templates/password_reset_confirm.html:19
msgid ""
"The password reset link was invalid, possibly because it has already been "
"used. Please request a new password reset."
msgstr ""
"Ссылка для сброса пароля недействительна, возможно, она уже была "
"использована. Пожалуйста, запросите новый сброс пароля."

#: src/common/templates/password_reset_confirm.html:20
msgid "Request new password reset"
msgstr "Запросить новый сброс пароля"

#: src/common/templates/password_reset_done.html:4
#: src/common/templates/password_reset_done.html:8
msgid "Password Reset Sent"
msgstr "Письмо для сброса пароля отправлено"

#: src/common/templates/password_reset_done.html:9
msgid ""
"We've emailed you instructions for setting your password. If an account "
"exists with the email you entered, you should receive them shortly."
msgstr ""
"Мы отправили вам инструкции для установки пароля на email. Если учетная "
"запись с указанным адресом существует, вы получите письмо в ближайшее время."

#: src/common/templates/password_reset_done.html:10
msgid ""
"If you don't receive an email, please make sure you've entered the address "
"you registered with, and check your spam folder."
msgstr ""
"Если вы не получили письмо, убедитесь, что указали адрес, с которым "
"регистрировались, и проверьте папку со спамом."

#: src/common/templates/password_reset_done.html:11
msgid "Return to login"
msgstr "Вернуться ко входу"

#: src/common/templates/password_reset_form.html:4
#: src/common/templates/password_reset_form.html:8
msgid "Password Reset"
msgstr "Сброс пароля"

#: src/common/templates/password_reset_form.html:9
msgid ""
"Forgotten your password? Enter your email address below, and we'll send you "
"instructions to set a new one."
msgstr ""
"Забыли пароль? Введите ваш email ниже, и мы отправим вам инструкции для "
"установки нового пароля."

#: src/common/templates/password_reset_form.html:14
msgid "Send reset link"
msgstr "Отправить ссылку для сброса"

#: src/common/templates/profile.html:14
msgid "Password"
msgstr "Пароль"

#: src/common/templates/profile.html:15 src/common/templates/profile.html:17
msgid "Change Password"
msgstr "Изменить пароль"

#: src/common/templates/profile.html:25
msgid "Email Address"
msgstr "Адрес электронной почты"

#: src/common/templates/profile.html:26
msgid "Current email:"
msgstr "Текущий email:"

#: src/common/templates/profile.html:33
msgid "Change Email"
msgstr "Изменить email"

#: src/common/views.py:73
#, python-format
msgid ""
"A confirmation email has been sent to %(email)s. Please check your email to "
"confirm the change."
msgstr ""
"Письмо с подтверждением отправлено на %(email)s. Пожалуйста, проверьте почту "
"для подтверждения изменения."

#: src/common/views.py:96
msgid "Your password has been changed successfully."
msgstr "Ваш пароль успешно изменен."

#: src/common/views.py:136
msgid "This email address is already in use by another account."
msgstr "Этот адрес электронной почты уже используется другой учетной записью."

#: src/common/views.py:145
msgid "Your email address has been changed successfully."
msgstr "Ваш адрес электронной почты успешно изменен."

#: src/common/views.py:155
msgid ""
"The email confirmation link is invalid or has expired. Please request a new "
"email change."
msgstr ""
"Ссылка подтверждения email недействительна или истекла. Пожалуйста, "
"запросите новое изменение email."
